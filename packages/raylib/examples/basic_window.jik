use "pkg/raylib"

func main():
    raylib::init_window(800, 450, "Jik + raylib")
    raylib::set_target_fps(60)

    while not raylib::window_should_close():
        center := raylib::Vector2{x = 200.0, y = 260.0}
        raylib::begin_drawing()
        raylib::clear_background(raylib::RAYWHITE)
        raylib::draw_text("Hello from Jik", 280, 180, 28, raylib::DARKGRAY)
        raylib::draw_circle(center, 45.0, raylib::RED)
        raylib::end_drawing()
    end

    raylib::close_window()
end
